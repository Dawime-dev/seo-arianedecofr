---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import siteConfig from '../../../site.config.json';

export async function getStaticPaths() {
  return siteConfig.categories.map((cat) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const allArticles = await getCollection('articles');

const articles = allArticles
  .filter((a) => a.data.category === category.slug)
  .sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime());

const featuredArticle = articles[0];
const otherArticles = articles.slice(1);
---

<BaseLayout
  title={`${category.name} — ${siteConfig.name}`}
  description={category.description}
>

  <!-- Header catégorie -->
  <header class="bg-[#1A1A1A] border-b-4 border-black">
    <div class="max-w-6xl mx-auto px-4 py-12 md:py-20">
      <nav class="font-mono text-xs text-gray-500 uppercase tracking-wide flex items-center gap-2 mb-8">
        <a href="/" class="hover:text-white transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-gray-300">{category.name}</span>
      </nav>
      <div class="border-l-4 border-white pl-6 md:pl-8">
        <p class="font-mono text-xs uppercase tracking-widest text-gray-500 mb-3">// Catégorie</p>
        <h1 class="font-mono font-bold text-4xl md:text-6xl text-white uppercase leading-none mb-4">
          {category.name}
        </h1>
        <p class="text-gray-400 text-lg max-w-2xl leading-relaxed">
          {category.description}
        </p>
        <div class="mt-6 font-mono text-xs text-gray-600 uppercase">
          {articles.length} article{articles.length > 1 ? 's' : ''}
        </div>
      </div>
    </div>
  </header>

  <!-- Contenu -->
  <div class="bg-white">
    <div class="max-w-6xl mx-auto px-4 py-12">

      {articles.length === 0 ? (
        <div class="border-4 border-dashed border-gray-300 p-16 text-center">
          <p class="font-mono text-gray-400 text-lg uppercase">// Aucun article pour l'instant</p>
          <p class="text-gray-400 mt-2">Revenez bientôt, du contenu arrive.</p>
          <a href="/" class="inline-block mt-6 font-mono font-bold text-sm uppercase border-2 border-black px-6 py-3 hover:bg-black hover:text-white transition-colors">
            ← Retour accueil
          </a>
        </div>
      ) : (
        <>
          {/* Article à la une */}
          {featuredArticle && (
            <div class="mb-0 border-2 border-black border-b-0">
              <div class="bg-[#1A1A1A] px-6 py-3 border-b-2 border-black">
                <span class="font-mono text-xs uppercase tracking-widest text-gray-400">// À la une</span>
              </div>
              <article class="grid grid-cols-1 md:grid-cols-2">
                {featuredArticle.data.image && (
                  <div class="overflow-hidden border-b-2 md:border-b-0 md:border-r-2 border-black">
                    <img
                      src={featuredArticle.data.image}
                      alt={featuredArticle.data.title}
                      class="w-full h-64 md:h-full object-cover grayscale hover:grayscale-0 transition-all duration-300"
                      loading="eager"
                    />
                  </div>
                )}
                <div class="p-8 md:p-10 flex flex-col justify-between">
                  <div>
                    <h2 class="font-mono font-bold text-2xl md:text-3xl leading-tight uppercase text-black mb-4">
                      <a href={`/${featuredArticle.slug}`} class="hover:underline underline-offset-4">
                        {featuredArticle.data.title}
                      </a>
                    </h2>
                    <p class="text-gray-600 leading-relaxed mb-6">
                      {featuredArticle.data.description}
                    </p>
                  </div>
                  <div class="flex items-center justify-between">
                    <a
                      href={`/${featuredArticle.slug}`}
                      class="font-mono font-bold text-sm uppercase bg-black text-white px-6 py-3 hover:bg-gray-800 transition-colors"
                    >
                      Lire →
                    </a>
                    {featuredArticle.data.publishedDate && (
                      <span class="font-mono text-xs text-gray-400">
                        {new Date(featuredArticle.data.publishedDate).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' })}
                      </span>
                    )}
                  </div>
                </div>
              </article>
            </div>
          )}

          {/* Grille des autres articles */}
          {otherArticles.length > 0 && (
            <div class="border-2 border-black border-t-0">
              <div class="bg-gray-100 px-6 py-3 border-b-2 border-black">
                <span class="font-mono text-xs uppercase tracking-widest text-gray-500">// Tous les articles</span>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
                {otherArticles.map((article, i) => {
                  const isLastRow = i >= otherArticles.length - (otherArticles.length % 3 || 3);
                  return (
                    <article class={`border-black ${
                      i % 3 !== 2 ? 'lg:border-r-2' : ''
                    } ${
                      i % 2 !== 1 ? 'sm:border-r-2 lg:border-r-0' : 'sm:border-r-0'
                    } ${
                      (i % 3 !== 2) ? 'lg:border-r-2' : ''
                    } border-b-2`}>
                      {article.data.image && (
                        <div class="overflow-hidden border-b-2 border-black">
                          <img
                            src={article.data.image}
                            alt={article.data.title}
                            class="w-full h-44 object-cover grayscale hover:grayscale-0 transition-all duration-300"
                            loading="lazy"
                          />
                        </div>
                      )}
                      <div class="p-5">
                        {article.data.publishedDate && (
                          <span class="font-mono text-xs text-gray-400 block mb-2">
                            {new Date(article.data.publishedDate).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' })}
                          </span>
                        )}
                        <h3 class="font-mono font-bold text-base leading-tight mb-3 text-black">
                          <a href={`/${article.slug}`} class="hover:underline underline-offset-4">
                            {article.data.title}
                          </a>
                        </h3>
                        <p class="text-gray-500 text-sm leading-relaxed mb-4 line-clamp-2">
                          {article.data.description}
                        </p>
                        <a href={`/${article.slug}`} class="font-mono text-xs font-bold uppercase border-b-2 border-black hover:text-gray-600 transition-colors">
                          Lire l'article →
                        </a>
                      </div>
                    </article>
                  );
                })}
              </div>
            </div>
          )}
        </>
      )}
    </div>
  </div>

  <!-- Autres catégories -->
  <section class="bg-[#1A1A1A] border-t-4 border-black">
    <div class="max-w-6xl mx-auto px-4 py-12">
      <div class="flex items-center gap-4 mb-8">
        <span class="font-mono text-xs uppercase tracking-widest text-gray-500">// Explorer</span>
        <h2 class="font-mono font-bold text-xl uppercase text-white">Autres catégories</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-0 border-2 border-white">
        {siteConfig.categories
          .filter(c => c.slug !== category.slug)
          .map((cat, i, arr) => (
            <a
              href={`/categorie/${cat.slug}`}
              class={`block p-6 border-black hover:bg-white group transition-colors ${
                i < arr.length - 1 ? 'border-b-2 sm:border-b-0 sm:border-r-2 border-white' : ''
              } ${i === 1 ? 'lg:border-r-2 border-white' : ''}`}
            >
              <p class="font-mono text-xs uppercase tracking-widest text-gray-500 mb-2 group-hover:text-gray-400">// {String(i + 1).padStart(2, '0')}</p>
              <p class="font-mono font-bold text-white uppercase text-lg group-hover:text-black leading-tight mb-2">{cat.name}</p>
              <p class="text-gray-500 text-sm group-hover:text-gray-600 line-clamp-2">{cat.description}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

</BaseLayout>
