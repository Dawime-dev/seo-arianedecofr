---
import BaseLayout from './BaseLayout.astro';
import siteConfig from '../../site.config.json';

interface Props {
  title: string;
  description?: string;
  image?: string;
  publishedDate?: Date | string;
  modifiedDate?: Date | string;
  author?: string;
  category?: string;
  categorySlug?: string;
  slug?: string;
}

const {
  title,
  description,
  image,
  publishedDate,
  modifiedDate,
  author = 'BétonBrut Maison',
  category,
  categorySlug,
  slug,
} = Astro.props;

const formattedDate = publishedDate
  ? new Date(publishedDate).toLocaleDateString('fr-FR', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null;

const formattedModified = modifiedDate
  ? new Date(modifiedDate).toLocaleDateString('fr-FR', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null;

const publishedISO = publishedDate ? new Date(publishedDate).toISOString() : undefined;
const modifiedISO = modifiedDate ? new Date(modifiedDate).toISOString() : undefined;

const categoryColors: Record<string, string> = {
  'decoration-interieure': 'bg-[#E8FF00] text-[#1A1A1A] border-[#1A1A1A]',
  'bricolage-travaux': 'bg-[#1A1A1A] text-white border-[#1A1A1A]',
  'amenagement-rangement': 'bg-white text-[#1A1A1A] border-[#1A1A1A]',
  'jardin-exterieur': 'bg-[#D4F5A0] text-[#1A1A1A] border-[#1A1A1A]',
};

const badgeClass = categorySlug && categoryColors[categorySlug]
  ? categoryColors[categorySlug]
  : 'bg-[#E8FF00] text-[#1A1A1A] border-[#1A1A1A]';
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  type="article"
  publishedDate={publishedISO}
  modifiedDate={modifiedISO}
  author={author}
  category={category}
  slug={slug ? `articles/${slug}` : undefined}
>
  <!-- Article Header -->
  <div class="bg-[#1A1A1A] border-b-4 border-[#E8FF00]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10 md:py-14">
      <!-- Breadcrumb -->
      <nav aria-label="Fil d'Ariane" class="mb-6">
        <ol class="flex items-center gap-2 text-xs flex-wrap" style="font-family: 'Space Mono', monospace;">
          <li>
            <a href="/" class="text-gray-400 hover:text-[#E8FF00] transition-colors uppercase tracking-widest">Accueil</a>
          </li>
          <li aria-hidden="true" class="text-gray-600 font-bold">/</li>
          {category && categorySlug && (
            <>
              <li>
                <a
                  href={`/categorie/${categorySlug}`}
                  class="text-gray-400 hover:text-[#E8FF00] transition-colors uppercase tracking-widest"
                >
                  {category}
                </a>
              </li>
              <li aria-hidden="true" class="text-gray-600 font-bold">/</li>
            </>
          )}
          <li>
            <span class="text-[#E8FF00] uppercase tracking-widest" aria-current="page">
              {title.length > 40 ? title.slice(0, 40) + '…' : title}
            </span>
          </li>
        </ol>
      </nav>

      <!-- Category badge -->
      {category && categorySlug && (
        <div class="mb-4">
          <a
            href={`/categorie/${categorySlug}`}
            class={`inline-block px-3 py-1 text-xs font-bold uppercase tracking-widest border-2 ${badgeClass}`}
            style="font-family: 'Space Mono', monospace;"
          >
            {category}
          </a>
        </div>
      )}

      <!-- Title -->
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight mb-6" style="font-family: 'Space Mono', monospace;">
        {title}
      </h1>

      <!-- Meta info -->
      <div class="flex flex-wrap items-center gap-4 text-sm">
        {formattedDate && (
          <div class="flex items-center gap-2 text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="square" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <time datetime={publishedISO} style="font-family: 'Space Mono', monospace;">
              {formattedDate}
            </time>
          </div>
        )}
        {formattedModified && formattedModified !== formattedDate && (
          <div class="flex items-center gap-2 text-gray-500 text-xs">
            <span style="font-family: 'Space Mono', monospace;">Mis à jour : {formattedModified}</span>
          </div>
        )}
        {author && (
          <div class="flex items-center gap-2 text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="square" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span style="font-family: 'Space Mono', monospace;">{author}</span>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Featured image -->
  {image && (
    <div class="max-w-4xl mx-auto px-4 sm:px-6 mt-8">
      <div class="border-4 border-[#1A1A1A]" style="box-shadow: 6px 6px 0px #1A1A1A;">
        <img
          src={image}
          alt={title}
          class="w-full max-h-[480px] object-cover block"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  )}

  <!-- Article body -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10">
    <div class="article-content">
      <slot />
    </div>

    <!-- Back link -->
    <div class="mt-12 pt-8 border-t-4 border-[#1A1A1A]">
      <a
        href={categorySlug ? `/categorie/${categorySlug}` : '/'}
        class="inline-flex items-center gap-2 px-5 py-3 bg-[#1A1A1A] text-white border-4 border-[#1A1A1A] font-bold text-sm uppercase tracking-widest hover:bg-[#E8FF00] hover:text-[#1A1A1A] transition-colors"
        style="font-family: 'Space Mono', monospace; box-shadow: 4px 4px 0px #555;"
      >
        <span aria-hidden="true">←</span>
        {category ? `Retour : ${category}` : 'Retour accueil'}
      </a>
    </div>
  </div>
</BaseLayout>
