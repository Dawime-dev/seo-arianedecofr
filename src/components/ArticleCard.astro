---
interface Props {
  title: string;
  description?: string;
  slug: string;
  category?: string;
  categorySlug?: string;
  date?: Date | string;
  image?: string;
  featured?: boolean;
}

const {
  title,
  description,
  slug,
  category,
  categorySlug,
  date,
  image,
  featured = false,
} = Astro.props;

const categoryColors: Record<string, string> = {
  'decoration-interieure': 'bg-[#E8FF00] text-[#1A1A1A]',
  'bricolage-travaux': 'bg-[#1A1A1A] text-white',
  'amenagement-rangement': 'bg-white text-[#1A1A1A]',
  'jardin-exterieur': 'bg-[#D4F5A0] text-[#1A1A1A]',
};

const badgeClass = categorySlug && categoryColors[categorySlug]
  ? categoryColors[categorySlug]
  : 'bg-[#E8FF00] text-[#1A1A1A]';

const formattedDate = date
  ? new Date(date).toLocaleDateString('fr-FR', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null;
---

<article class={`group bg-white border-4 border-[#1A1A1A] flex flex-col h-full brutalist-shadow-hover ${featured ? 'md:flex-row' : ''}`} style="box-shadow: 5px 5px 0px #1A1A1A;">
  <!-- Image -->
  {image && (
    <a
      href={`/articles/${slug}`}
      class={`block overflow-hidden border-b-4 border-[#1A1A1A] flex-shrink-0 ${featured ? 'md:w-2/5 md:border-b-0 md:border-r-4' : ''}`}
      tabindex="-1"
      aria-hidden="true"
    >
      <img
        src={image}
        alt={title}
        loading="lazy"
        decoding="async"
        class={`w-full object-cover group-hover:scale-105 transition-transform duration-300 ${featured ? 'h-48 md:h-full' : 'h-48'}`}
      />
    </a>
  )}

  {!image && (
    <a
      href={`/articles/${slug}`}
      class={`block bg-[#1A1A1A] flex-shrink-0 flex items-center justify-center border-b-4 border-[#1A1A1A] ${featured ? 'md:w-2/5 md:border-b-0 md:border-r-4 h-48 md:h-auto' : 'h-40'}`}
      tabindex="-1"
      aria-hidden="true"
    >
      <span class="text-[#E8FF00] text-4xl font-bold" style="font-family: 'Space Mono', monospace;">BB</span>
    </a>
  )}

  <!-- Content -->
  <div class="flex flex-col flex-1 p-4 md:p-5">
    <!-- Category + Date -->
    <div class="flex items-center justify-between gap-2 mb-3 flex-wrap">
      {category && categorySlug && (
        <a
          href={`/categorie/${categorySlug}`}
          class={`inline-block px-2 py-1 text-xs font-bold uppercase tracking-widest border-2 border-[#1A1A1A] ${badgeClass}`}
          style="font-family: 'Space Mono', monospace;"
        >
          {category}
        </a>
      )}
      {formattedDate && (
        <time
          datetime={new Date(date!).toISOString()}
          class="text-xs text-gray-500 flex-shrink-0"
          style="font-family: 'Space Mono', monospace;"
        >
          {formattedDate}
        </time>
      )}
    </div>

    <!-- Title -->
    <h3 class={`font-bold leading-tight mb-3 group-hover:text-gray-600 transition-colors ${featured ? 'text-xl md:text-2xl' : 'text-base md:text-lg'}`} style="font-family: 'Space Mono', monospace;">
      <a href={`/articles/${slug}`} class="hover:underline decoration-2 underline-offset-2">
        {title}
      </a>
    </h3>

    <!-- Description -->
    {description && (
      <p class={`text-gray-600 leading-relaxed mb-4 flex-1 ${featured ? 'text-base' : 'text-sm'}`}>
        {description.length > 120 ? description.slice(0, 120) + '…' : description}
      </p>
    )}

    <!-- CTA -->
    <div class="mt-auto pt-2">
      <a
        href={`/articles/${slug}`}
        class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest border-2 border-[#1A1A1A] px-3 py-2 bg-[#1A1A1A] text-white hover:bg-[#E8FF00] hover:text-[#1A1A1A] hover:border-[#1A1A1A] transition-colors duration-150"
        style="font-family: 'Space Mono', monospace;"
      >
        Lire l'article
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</article>
